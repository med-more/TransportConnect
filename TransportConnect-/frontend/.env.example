# Copy to .env and fill in values
VITE_API_BASE_URL=http://localhost:7000/api
VITE_SOCKET_URL=http://localhost:7000

# Tracking map uses MapLibre GL + Carto (no API key required).
# Optional: MapTiler for more detail (streets, 3D). Get key at https://www.maptiler.com/
# VITE_MAPTILER_API_KEY=your_maptiler_key
# Optional: Traffic overlay (raster tiles URL with {z}/{x}/{y}). e.g. TomTom Traffic Flow.
# VITE_MAP_TRAFFIC_TILES_URL=https://api.tomtom.com/traffic/map/4/tile/flow/{z}/{x}/{y}.png?key=YOUR_KEY
